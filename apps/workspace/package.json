{
  "name": "react-spa-template",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "vite --host 127.0.0.1 --port 1420 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm run lint && pnpm run format",
    "check:fix": "pnpm run lint:fix && pnpm run format:fix"
  },
  "dependencies": {
    "@a2ui/react": "0.10.0",
    "@a2ui/web_core": "0.10.0",
    "@dnd-kit/core": "^6.3.1",
    "@lobehub/icons-static-svg": "1.91.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-heading": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-mention": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-table-cell": "^3.23.4",
    "@tiptap/extension-table-header": "^3.23.4",
    "@tiptap/extension-table-row": "^3.23.4",
    "@tiptap/markdown": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/suggestion": "3.23.4",
    "@vidstack/react": "^1.15.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.8",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-json-view-lite": "^2.5.0",
    "react-photo-view": "^1.2.7",
    "react-router-dom": "^7.13.0",
    "react-virtuoso": "^4.18.7",
    "sonner": "^2.0.7",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tippy.js": "^6.3.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "git-cz": "^4.9.0",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix",
      "oxfmt --write --no-error-on-unmatched-pattern"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "oxfmt --write --no-error-on-unmatched-pattern"
    ]
  },
  "packageManager": "pnpm@10.14.0"
}
