# 应用配置
VITE_APP_NAME=MediaGo Drama
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# MediaGo「我的词包」发布入口。可选覆盖；未配置时默认使用线上地址。
# 本地联调时设置为本地官网，Taskfile 的开发任务也会自动注入该地址。
VITE_MEDIAGO_PROMPT_PACK_PUBLISH_URL="http://localhost:4321/account#promptPacks"

# TalkingData 应用统计分析 App ID；留空则不加载统计 SDK。
VITE_TALKINGDATA_APP_ID=
