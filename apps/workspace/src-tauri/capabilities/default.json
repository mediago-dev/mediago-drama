{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:allow-start-dragging",
		"dialog:default",
		"notification:default",
		"opener:default",
		{
			"identifier": "shell:allow-spawn",
			"allow": [
				{
					"name": "binaries/mediago-server",
					"sidecar": true
				}
			]
		},
		"shell:allow-kill"
	]
}
